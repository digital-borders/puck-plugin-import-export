{
  "name": "@digital-borders/puck-plugin-import-export",
  "version": "0.2.0",
  "description": "Import / Export plugin for @puckeditor/core",
  "license": "MIT",
  "author": "Digital Borders",
  "repository": {
    "type": "git",
    "url": "https://github.com/digital-borders/puck-plugin-import-export"
  },
  "type": "module",
  "keywords": [
    "puck",
    "puck-editor",
    "puck-plugin",
    "import",
    "export",
    "editor",
    "react"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build:css": "npx @tailwindcss/cli -c tailwind.config.ts -i src/styles.css -o dist/styles.css --minify",
    "build": "npm run lint && npx rimraf dist && tsup && npm run build:css",
    "dev": "tsup --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepare": "husky",
    "prepublishOnly": "node prepublish.js",
    "release": "RELEASE_MODE=true release-it"
  },
  "peerDependencies": {
    "@puckeditor/core": "^0.21.0",
    "react": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "@eslint/js": "^9.39.3",
    "@release-it/conventional-changelog": "^10.0.5",
    "@tailwindcss/cli": "^4.2.1",
    "@types/react": "^19.0.0",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.39.3",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "husky": "^9.1.7",
    "release-it": "^19.2.4",
    "tailwindcss": "^4.2.1",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-separator": "^1.1.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.575.0",
    "tailwind-merge": "^3.5.0",
    "uuid": "^13.0.0"
  }
}
